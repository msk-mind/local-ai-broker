#!/usr/bin/env bash
# copilot-slurm-broker: launches Copilot CLI with the Slurm broker MCP server active.
# Equivalent to: copilot --additional-mcp-config @~/.copilot/profiles/slurm-broker.mcp-config.json
set -euo pipefail
exec "__COPILOT_BIN__" --allow-all-mcp-server-instructions --additional-mcp-config "@${HOME}/.copilot/profiles/slurm-broker.mcp-config.json" "$@"
