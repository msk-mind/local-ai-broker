e":"go","symbol":"contextKey","line_start":22,"line_end":25,"content":"\ntype contextKey string\n\nconst principalContextKey contextKey = \"broker_principal\"","content_hash":"sha256:cecf98ce54f2173098df6d2064e659ec87854dbe96bfa5a616068bb752c7d44f","chunk_hash":"sha256:cecf98ce54f2173098df6d2064e659ec87854dbe96bfa5a616068bb752c7d44f","token_estimate":20,"input_id":"input_0","input_type":"repo","classification":"unknown"},{"chunk_id":"chunk_b2afb97cdd3dcdefc828","path":"broker/pkg/auth/auth.go","repository_path":"broker/pkg/auth/auth.go","source_namespace":"input_0","language":"go","symbol":"NewHeaderAuthenticator","line_start":26,"line_end":29,"content":"\nfunc NewHeaderAuthenticator() *Authenticator {\n\treturn &Authenticator{allowHeaderIdentity: true}\n}","content_hash":"sha256:b62b8367bce2785c29af8ef5cb8c584f2f1f21672eb920e6ea7fe9ac5b3a7369","chunk_hash":"sha256:b62b8367bce2785c29af8ef5cb8c584f2f1f21672eb920e6ea7fe9ac5b3a7369","token_estimate":24,"input_id":"input_0","input_type":"repo","classification":"unknown"},{"chunk_id":"chunk_6c0185a19c3fa600f2b9","path":"broker/pkg/auth/auth.go","repository_path":"broker/pkg/auth/auth.go","source_namespace":"input_0","language":"go","symbol":"NewStaticTokenAuthenticator","line_start":30,"line_end":33,"content":"\nfunc NewStaticTokenAuthenticator(staticTokens map[string]Principal) *Authenticator {\n\treturn &Authenticator{staticTokens: staticTokens}\n}","content_hash":"sha256:0b33a602667c85293cbd4e36fba1a74c4fd727b7b04dfbece63219c99682f584","chunk_hash":"sha256:0b33a602667c85293cbd4e36fba1a74c4fd727b7b04dfbece63219c99682f584","token_estimate":34,"input_id":"input_0","input_type":"repo","classification":"unknown"},{"chunk_id":"chunk_8546ab104710aba8dfd2","path":"broker/pkg/auth/auth.go","repository_path":"broker/pkg/auth/auth.go","source_namespace":"input_0","language":"go","symbol":"WithPrincipal","line_start":34,"line_end":37,"content":"\nfunc WithPrincipal(ctx context.Context, principal Principal) context.Context {\n\treturn context.WithValue(ctx, principalContextKey, principal)\n}","content_hash":"sha256:e13f487ee17265c23b59740277db09e775b0e07af755135b8732ca7f490a8967","chunk_hash":"sha256:e13f487ee17265c23b59740277db09e775b0e07af755135b8732ca7f490a8967","token_estimate":36,"input_id":"input_0","input_type":"repo","classification":"unknown"},{"chunk_id":"chunk_b1d50fca6ae9dfe2f913","path":"broker/pkg/auth/auth.go","repository_path":"broker/pkg/auth/auth.go","source_namespace":"input_0","language":"go","symbol":"PrincipalFromContext","line_start":38,"line_end":42,"content":"\nfunc PrincipalFromContext(ctx context.Context) Principal {\n\tprincipal, _ := ctx.Value(principalContextKey).(Principal)\n\treturn principal\n}","content_hash":"sha256:d77f5c71bded5d1fb39231742ce0e9f52131499b21c25bde2384d0e6aec44124","chunk_hash":"sha256:d77f5c71bded5d1fb39231742ce0e9f52131499b21c25bde2384d0e6aec44124","token_estimate":34,"input_id":"input_0","input_type":"repo","classification":"unknown"},{"chunk_id":"chunk_f1c74070edd7b569291d","path":"broker/pkg/auth/auth.go","repository_path":"broker/pkg/auth/auth.go","source_namespace":"input_0","language":"go","symbol":"Authenticate","line_start":43,"line_end":63,"content":"\nfunc (a *Authenticator) Authenticate(r *http.Request) (Principal, error) {\n\tif a == nil {\n\t\treturn PrincipalFromHeaders(r.Header), nil\n\t}\n\tif len(a.staticTokens) > 0 {\n\t\ttoken, err := bearerToken(r.Header.Get(\"Authorization\"))\n\t\tif err != nil {\n\t\t\treturn Principal{}, err\n\t\t}\n\t\tprincipal, ok := a.staticTokens[token]\n\t\tif !ok {\n\t\t\treturn Principal{}, fmt.Errorf(\"%w: invalid bearer token\", ErrUnauthenticated)\n\t\t}\n\t\treturn principal, nil\n\t}\n\tif a.allowHeaderIdentity {\n\t\treturn PrincipalFromHeaders(r.Header), nil\n\t}\n\treturn Principal{}, fmt.Errorf(\"%w: no authentication method configured\", ErrUnauthenticated)\n}","content_hash":"sha256:fec30ba629f918169fd5484e0d7956f64439e200070a88afc4f40d0c8ed4d9b2","chunk_hash":"sha256:fec30ba629f918169fd5484e0d7956f64439e200070a88afc4f40d0c8ed4d9b2","token_estimate":153,"input_id":"input_0","input_type":"repo","classification":"unknown"},{"chunk_id":"chunk_23c48bc63f8b8d8547be","path":"broker/pkg/auth/auth.go","repository_path":"broker/pkg/auth/auth.go","source_namespace":"input_0","language":"go","symbol":"PrincipalFromHeaders","line_start":64,"line_end":78,"content":"\nfunc PrincipalFromHeaders(header http.Header) Principal {\n\tactor := strings.TrimSpace(header.Get(\"X-Broker-Actor\"))\n\tif actor == \"\" {\n\t\tactor = \"anonymous\"\n\t}\n\trole := strings.TrimSpace(header.Get(\"X-Broker-Role\"))\n\tif role == \"\" {\n\t\trole = \"user\"\n\t}\n\treturn Principal{\n\t\tActor: actor,\n\t\tRole:  role,\n\t}\n}","content_hash":"sha256:849d1835f608b8d232ccf80ac1c2253b028d35654dfbffe020e0d0ad4e8c7fe1","chunk_hash":"sha256:849d1835f608b8d232ccf80ac1c2253b028d35654dfbffe020e0d0ad4e8c7fe1","token_estimate":76,"input_id":"input_0","input_type":"repo","classification":"unknown"},{"chunk_id":"chunk_bffa77100c653e7acae8","path":"broker/pkg/auth/auth.go","repository_path":"broker/pkg/auth/auth.go","source_namespace":"input_0","language":"go","symbol":"ParseStaticTokens","line_start":79,"line_end":106,"content":"\nfunc ParseStaticTokens(raw string) (map[string]Principal, error) {\n\tif strings.TrimSpace(raw) == \"\" {\n\t\treturn nil, nil\n\t}\n\tout := make(map[string]Principal)\n\tentries := strings.Split(raw, \",\")\n\tfor _, entry := range entries {\n\t\tentry = strings.TrimSpace(entry)\n\t\tif entry == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\ttokenAndPrincipal := strings.SplitN(entry, \"=\", 2)\n\t\tif len(tokenAndPrincipal) != 2 {\n\t\t\treturn nil, fmt.Errorf(\"invalid token mapping %q\", entry)\n\t\t}\n\t\ttoken := strings.TrimSpace(tokenAndPrincipal[0])\n\t\tactorAndRole := strings.SplitN(strings.TrimSpace(tokenAndPrincipal[1]), \":\", 2)\n\t\tif token == \"\" || len(actorAndRole) != 2 {\n\t\t\treturn nil, fmt.Errorf(\"invalid token mapping %q\", entry)\n\t\t}\n\t\tout[token] = Principal{\n\t\t\tActor: strings.TrimSpace(actorAndRole[0]),\n\t\t\tRole:  strings.TrimSpace(actorAndRole[1]),\n\t\t}\n\t}\n\treturn out, nil\n}","content_hash":"sha256:24e038fd9766d876b203b824eebb1dad51bb9029eaa0b896f1775470ce9e04de","chunk_hash":"sha256:24e038fd9766d876b203b824eebb1dad51bb9029eaa0b896f1775470ce9e04de","token_estimate":209,"input_id":"input_0","input_type":"repo","classification":"unknown"},{"chunk_id":"chunk_3f6a964e07f54a09484e","path":"broker/pkg/auth/auth.go","repository_path":"broker/pkg/auth/auth.go","source_namespace":"input_0","language":"go","symbol":"IsAdmin","line_start":107,"line_end":110,"content":"\nfunc IsAdmin(principal Principal) bool {\n\treturn strings.EqualFold(principal.Role, \"admin\")\n}","content_hash":"sha256:27d55f256a81d632c33188ff957e48ebf7db61b19f344ba92d5a4fc89a3a327d","chunk_hash":"sha256:27d55f256a81d632c33188ff957e48ebf7db61b19f344ba92d5a4fc89a3a327d","token_estimate":23,"input_id":"input_0","input_type":"repo","classification":"unknown"},{"chunk_id":"chunk_715e0f150467c32d56bb","path":"broker/pkg/auth/auth.go","repository_path":"broker/pkg/auth/auth.go","source_namespace":"input_0","language":"go","symbol":"bearerToken","line_start":111,"line_end":122,"content":"\nfunc bearerToken(header string) (string, error) {\n\theader = strings.TrimSpace(header)\n\tif header == \"\" {\n\t\treturn \"\", fmt.Errorf(\"%w: missing bearer token\", ErrUnauthenticated)\n\t}\n\tparts := strings.SplitN(header, \" \", 2)\n\tif len(parts) != 2 || !strings.EqualFold(parts[0], \"Bearer\") || strings.TrimSpace(parts[1]) == \"\" {\n\t\treturn \"\", fmt.Errorf(\"%w: invalid authorization header\", ErrUnauthenticated)\n\t}\n\treturn strings.TrimSpace(parts[1]), nil\n}","content_hash":"sha256:ffca0a474216a8f167c0378a87256b580d6c8ff84b2f7e688b53b5db6eb1abcc","chunk_hash":"sha256:ffca0a474216a8f167c0378a87256b580d6c8ff84b2f7e688b53b5db6eb1abcc","token_estimate":112,"input_id":"input_0","input_type":"repo","classification":"unknown"}]