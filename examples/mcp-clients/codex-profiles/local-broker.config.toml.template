developer_instructions = """
When this broker profile is active, use the `local-ai-compute-broker` MCP server by default for local context work.

Use broker tools first for:
- repository inspection
- log analysis
- retrieval/compression of local context
- local debugging passes over code or logs
- patch-oriented investigation when broker evidence is useful

Prefer `inspect_repo`, `summarize_logs`, `debug_with_local_context`, `rag_compress`, and `propose_patch` over direct ad hoc repository inspection when the task can be broker-mediated.

Only skip the broker when:
- the task is trivial and does not benefit from local retrieval or compression
- the broker is unavailable
- the broker result is degraded, non-authoritative, or clearly insufficient for the task

If the broker returns degraded retrieval quality, treat it as non-authoritative and verify directly in the repo before making strong claims.
"""

mcp_servers."local-ai-compute-broker".command = "__REPO_ROOT__/examples/mcp-clients/run_broker_mcp.sh"
mcp_servers."local-ai-compute-broker".startup_timeout_sec = 60

[mcp_servers."local-ai-compute-broker".env]
BROKER_BACKEND = "local"
BROKER_LOCAL_MODE = "command"
BROKER_LOCAL_SCRIPT_PATH = "__REPO_ROOT__/deploy/local/broker_worker.sh"
BROKER_JOB_STORE_PATH = "__REPO_ROOT__/.broker/codex-local-jobs.json"
BROKER_RUN_ROOT_PATH = "__REPO_ROOT__/.broker/codex-local-runs"
BROKER_REPO_ROOT_PATH = "__REPO_ROOT__"
BROKER_AUDIT_LOG_PATH = "__REPO_ROOT__/.broker/codex-local-audit.jsonl"
BROKER_MCP_ACTOR = "codex-cli"
BROKER_MCP_ROLE = "user"
