REPO_ROOT=/gpfs/mskmind_ess/limr/repos/local-ai-broker

BROKER_LISTEN_ADDR=127.0.0.1:18081
BROKER_JOB_STORE_PATH=${REPO_ROOT}/.broker/jobs.json
BROKER_RUN_ROOT_PATH=${REPO_ROOT}/.broker/runs
BROKER_REPO_ROOT_PATH=${REPO_ROOT}
BROKER_AUDIT_LOG_PATH=${REPO_ROOT}/.broker/audit.jsonl
BROKER_AUDIT_VERIFY_MODE=warn

BROKER_AUTH_MODE=header

BROKER_BACKEND=slurm
BROKER_SLURM_MODE=command
BROKER_SLURM_SUBMIT_CMD=sbatch
BROKER_SLURM_STATUS_CMD=sacct
BROKER_SLURM_CANCEL_CMD=scancel
BROKER_SLURM_INFO_CMD=sinfo
BROKER_SLURM_SCRIPT_PATH=${REPO_ROOT}/deploy/slurm/broker_worker.slurm

# CDSI placement defaults.
BROKER_SLURM_PARTITION_GPU=hpc
BROKER_SLURM_GPU_REQUEST_MODE=gres
BROKER_SLURM_GPU_TYPE_P40=p40
BROKER_SLURM_GPU_TYPE_V100=v100
BROKER_SLURM_GPU_TYPE_A100=a100
BROKER_SLURM_NODELIST_P40=pllimsksparky[1-4]

BROKER_GPU_SERVICE_ENABLED=true
BROKER_GPU_SERVICE_REGISTRY_PATH=${REPO_ROOT}/.broker/gpu-services.json
BROKER_GPU_SERVICE_CONTROL_REQUEST_DIR=${REPO_ROOT}/.broker/gpu-services.json.requests
BROKER_GPU_SERVICE_CONTROL_TOKEN=9Vd8B8cDgYdH3P3qk4s8Q2xV6mL7rN1tW5zJ0cK6fP4a
BROKER_GPU_SERVICE_SCRIPT_PATH=${REPO_ROOT}/deploy/slurm/gpu_service.slurm
BROKER_GPU_SERVICE_LEASE_DURATION_SECONDS=14400
BROKER_GPU_SERVICE_HEALTH_INTERVAL_SECONDS=15
BROKER_GPU_SERVICE_HEARTBEAT_TIMEOUT_SECONDS=45
BROKER_GPU_SERVICE_STARTUP_TIMEOUT_SECONDS=600
BROKER_GPU_SERVICE_INDEX_CACHE_DIR=${REPO_ROOT}/.broker/semantic-index-cache
